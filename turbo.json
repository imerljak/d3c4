{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build",
                "generate"
            ],
            "outputs": [
                "dist/**",
                "lib/**",
                "build/**"
            ]
        },
        "generate": {
            "inputs": [
                "**/*.g4"
            ],
            "outputs": [
                "src/generated/**"
            ]
        },
        "test": {
            "dependsOn": [
                "build"
            ],
            "outputs": []
        },
        "typecheck": {
            "dependsOn": [
                "^build"
            ],
            "outputs": []
        },
        "lint": {
            "outputs": []
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "preview": {
            "cache": false,
            "persistent": true
        }
    }
}