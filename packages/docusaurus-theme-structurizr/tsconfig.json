{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "outDir": "lib",
        "rootDir": "src",
        "jsx": "react-jsx",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "es2022",
        "declaration": true,
        "esModuleInterop": true
    },
    "include": [
        "src"
    ],
    "exclude": [
        "node_modules",
        "lib"
    ]
}