{
    "name": "@d3c4/docusaurus-theme-structurizr",
    "version": "0.1.1",
    "main": "lib/index.js",
    "types": "lib/index.d.ts",
    "files": [
        "lib"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/imerljak/d3c4",
        "directory": "packages/docusaurus-theme-structurizr"
    },
    "publishConfig": {
        "access": "public"
    },
    "exports": {
