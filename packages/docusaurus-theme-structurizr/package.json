    },
    "dependencies": {
        "@d3c4/core": "workspace:*",
        "@d3c4/dsl": "workspace:*",
        "@d3c4/react": "workspace:*",
        "clsx": "^2.0.0",
        "unist-util-visit": "^5.1.0"
    },
    "devDependencies": {
        "@docusaurus/types": "^3.0.0",
        "@types/mdast": "^4.0.4",
        "@types/node": "^20.0.0",
        "@types/react": "^18.0.0",
        "typescript": "^5.5.0"
    }
