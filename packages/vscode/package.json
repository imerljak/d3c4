{
  "name": "d3c4",
  "displayName": "d3c4",
  "description": "Structurizr DSL preview and tooling for VS Code",
  "version": "0.0.1",
  "publisher": "d3c4",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization"
  ],
  "keywords": [
    "structurizr",
    "c4",
    "architecture",
    "dsl"
  ],
  "activationEvents": [
    "onLanguage:structurizr"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "structurizr",
        "aliases": [
          "Structurizr DSL",
          "structurizr"
        ],
        "extensions": [
          ".dsl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "structurizr",
        "scopeName": "source.structurizr",
        "path": "./syntaxes/structurizr.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "structurizr",
        "path": "./snippets/structurizr.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "d3c4.helloWorld",
        "title": "d3c4: Hello World"
      },
      {
        "command": "d3c4.openPreview",
        "title": "d3c4: Open Preview to the Side",
        "icon": "$(open-preview)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "d3c4.openPreview",
          "when": "resourceLangId == structurizr",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "d3c4",
      "properties": {
        "d3c4.preview.updateMode": {
          "type": "string",
          "enum": ["onSave", "onType"],
          "default": "onSave",
          "description": "When to update the diagram preview: on every file save, or live on each keystroke."
        },
        "d3c4.preview.debounceDelay": {
          "type": "number",
          "default": 300,
          "minimum": 0,
          "description": "Debounce delay in milliseconds used when `d3c4.preview.updateMode` is `onType`."
        },
        "d3c4.preview.defaultView": {
          "type": "string",
          "default": "first",
          "description": "Key of the view to show by default in the preview panel. Use `\"first\"` to always show the first view defined in the DSL."
        },
        "d3c4.export.pngScale": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "description": "Scale factor for PNG export resolution (e.g. `2` produces a 2× image)."
        }
      }
    }
  },
  "scripts": {
    "build": "vite build && vite build --config vite.webview.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@d3c4/core": "workspace:*",
    "@d3c4/dsl": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.5.0",
    "vite": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/imerljak/d3c4",
    "directory": "packages/vscode"
  }
}
