{
  "name": "@d3c4/dsl",
  "version": "0.1.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/imerljak/d3c4",
    "directory": "packages/dsl"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "generate": "antlr-ng -Dlanguage=TypeScript -l false -v true -o src/generated src/StructurizrDsl.g4"
  },
  "dependencies": {
    "@d3c4/types": "workspace:*",
    "antlr4ng": "^3.0.16"
  },
  "devDependencies": {
    "antlr-ng": "^1.0.10",
    "typescript": "^5.5.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.9.0",
    "vitest": "^1.6.0"
  }
